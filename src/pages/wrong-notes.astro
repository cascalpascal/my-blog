---
// src/pages/wrong-notes.astro
import { getCollection } from 'astro:content';

// 1. 블로그 데이터 중 '오답' 태그가 붙은 글만 필터링
const allPosts = await getCollection('blog');
const wrongPosts = allPosts
    .filter((post: any) => post.data.tags?.includes('오답'))
    .sort((a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="ko">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>📕 오답노트 모아보기</title>
		<link href="https://cdnjs.cloudflare.com/ajax/libs/flowbite/2.3.0/flowbite.min.css" rel="stylesheet" />
	</head>
	<body class="bg-[#fafafa] text-gray-800 antialiased min-h-screen flex flex-col">

		<nav class="fixed top-0 z-50 w-full bg-white border-b border-gray-100 h-16 flex items-center justify-between px-6">
			<div class="flex items-center gap-3">
				<button id="toggle-sidebar-btn" type="button" class="inline-flex items-center p-2 text-sm text-gray-500 rounded-lg hover:bg-gray-100 focus:outline-none">
					<svg class="w-6 h-6" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
						<path clip-rule="evenodd" fill-rule="evenodd" d="M2 4.75A.75.75 0 012.75 4h14.5a.75.75 0 010 1.5H2.75A.75.75 0 012 4.75zm0 10.5a.75.75 0 01.75-.75h14.5a.75.75 0 010 1.5H2.75a.75.75 0 01-.75-.75zm0-5.25a.75.75 0 01.75-.75h14.5a.75.75 0 010 1.5H2.75a.75.75 0 01-.75-.75z"></path>
					</svg>
				</button>
			</div>
			<div class="relative w-64 flex items-center">
				<input type="text" class="w-full bg-gray-50 border border-gray-200 text-gray-900 text-xs rounded-xl focus:ring-amber-500 focus:border-amber-500 p-2 pl-3" placeholder="오답 검색">
			</div>
		</nav>

		<div class="flex flex-1 pt-16 h-[calc(100vh-4rem)] overflow-hidden">
			<aside id="main-sidebar" class="w-16 h-full bg-white border-r border-gray-100 overflow-y-auto overflow-x-hidden flex-shrink-0 transition-all duration-300">
				<div class="h-full px-2 py-4 flex flex-col justify-between">
					<div>
						<div id="sidebar-profile" class="hidden flex items-center gap-3 px-2 mb-6 transition-opacity duration-200">
							<div class="w-9 h-9 min-w-[36px] rounded-full bg-amber-100 flex items-center justify-center font-bold text-amber-700 text-sm">메뉴</div>
						</div>
						<ul class="space-y-2 font-medium text-xs">
							<li><a href="/" class="flex items-center justify-center p-2.5 text-gray-600 rounded-xl hover:bg-gray-50 sidebar-link" title="소개"><span class="text-base min-w-[28px] text-center">👤</span><span class="sidebar-text hidden ml-2 whitespace-nowrap opacity-0 transition-all duration-200">소개</span></a></li>
							<li><a href="/todo" class="flex items-center justify-center p-2.5 text-gray-600 rounded-xl hover:bg-gray-50 sidebar-link" title="학습 일정"><span class="text-base min-w-[28px] text-center">📅</span><span class="sidebar-text hidden ml-2 whitespace-nowrap opacity-0 transition-all duration-200">학습 일정</span></a></li>
							<li><a href="/blog" class="flex items-center justify-center p-2.5 text-gray-600 rounded-xl hover:bg-gray-50 sidebar-link" title="필기"><span class="text-base min-w-[28px] text-center">📝</span><span class="sidebar-text hidden ml-2 whitespace-nowrap opacity-0 transition-all duration-200">필기</span></a></li>
							<li><a href="/wrong-notes" class="flex items-center justify-center p-2.5 text-amber-600 rounded-xl bg-amber-50/60 font-semibold sidebar-link" title="오답노트"><span class="text-base min-w-[28px] text-center">📕</span><span class="sidebar-text hidden ml-2 whitespace-nowrap opacity-0 transition-all duration-200">오답노트</span></a></li>
						</ul>
					</div>
					<div class="text-[9px] text-gray-400 sidebar-text hidden opacity-0 whitespace-nowrap text-center">© 2026</div>
				</div>
			</aside>

			<main class="flex-1 p-6 h-full overflow-y-auto">
				<div class="max-w-5xl mx-auto space-y-6">
					<div>
						<h1 class="text-xl font-bold text-gray-800">📕 취약점 분석 오답노트</h1>
						<p class="text-xs text-gray-400 mt-1">내가 틀린 문제들을 복기하고 실수를 줄이는 공간입니다.</p>
					</div>

					{wrongPosts.length === 0 ? (
						<div class="bg-white p-12 text-center rounded-2xl border border-gray-100 shadow-sm">
							<span class="text-3xl">🎉</span>
							<p class="text-sm text-gray-500 font-medium mt-3">틀린 문제가 없습니다! 완벽해요.</p>
						</div>
					) : (
						<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
							{wrongPosts.map((post: any) => (
								<div class="bg-white p-5 rounded-2xl border border-gray-100 shadow-sm flex flex-col justify-between hover:border-red-200 transition-colors">
									<div>
										<div class="flex justify-between items-center mb-2">
											<span class="bg-red-50 text-red-600 font-bold px-2 py-0.5 rounded-md text-[10px]">오답 복기</span>
											<span class="text-[10px] text-gray-400">{post.data.pubDate.toLocaleDateString('ko-KR')}</span>
										</div>
										<a href={`/blog/${post.id}/`} class="text-sm font-bold text-gray-800 hover:text-red-500 block mb-2 transition-colors">
											{post.data.title}
										</a>
										<p class="text-xs text-gray-500 line-clamp-2 mb-4">
											{post.data.description || "상세 내용을 확인해 보세요."}
										</p>
									</div>
									<div class="flex justify-between items-center pt-3 border-t border-gray-50 text-[11px]">
										<span class="text-gray-400">작성자: {post.data.author}</span>
										<a href={`/blog/${post.id}/`} class="text-red-500 font-semibold hover:underline">리뷰하기 →</a>
									</div>
								</div>
							))}
						</div>
					)}
				</div>
			</main>
		</div>

		<script>
			// 사이드바 토글 로직
			const toggleBtn = document.getElementById('toggle-sidebar-btn');
			const sidebar = document.getElementById('main-sidebar');
			const profile = document.getElementById('sidebar-profile');
			const texts = document.querySelectorAll('.sidebar-text');
			const links = document.querySelectorAll('.sidebar-link');

			toggleBtn?.addEventListener('click', () => {
				sidebar?.classList.toggle('w-16');
				sidebar?.classList.toggle('w-64');
				profile?.classList.toggle('hidden');
				texts.forEach(text => {
					text.classList.toggle('hidden');
					setTimeout(() => { text.classList.toggle('opacity-0'); }, 50);
				});
				links.forEach(link => {
					link.classList.toggle('justify-center');
					link.classList.toggle('justify-start');
				});
			});
		</script>
	</body>
</html>